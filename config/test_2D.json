{
    "name": "Fus",
    "phase": "test",
    "gpu_ids": [8],
    "distributed": true,
    "display_port": 8097,
    "path": {
        "log": "logs",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": null
    },
    "datasets": {
        "centered": true,
        "test": {
            "name": "reg",
            "crop_size": 256,
            "dataroot_ir": "./",
            "dataroot_vi": "./",
            "batch_size": 1,                                        
            "num_workers": 8,
            "use_shuffle": false,
            "is_crop"    : false
        }
    },
    "model": {
        "task": "VI-IR",
        "feat": {
            "img_size": 256,
            "in_channel": 1,
            "embed_dim": 32,
            "patch_size": 4,
            "depth": 4,
            "d_state": 4
        }  
    },
    "train": {
        "n_epoch": 241,
        "val_freq": 2,
        "save_checkpoint_epoch": 120,
        "print_freq": 2,
        "ema_decay": 0.999,
        "warmup_iter": -1,
        "scheduler":{
            "type": "CosineAnnealingRestartCyclicLR",
            "periods": [60, 60,60,61],
            "restart_weights": [1,1,0.5,0.5],
            "eta_mins": [0.0003, 0.00001, 0.00001, 0.00001]
        },
        "optimizer": {
            "type": "AdamW",
            "lr": 3e-4,
            "weight_decay": 1e-4
        }
    }
}